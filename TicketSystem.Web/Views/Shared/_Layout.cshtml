<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TicketSystem</title>
    <script>
            (function () {
                const savedTheme = localStorage.getItem('theme') || 'light';
                document.documentElement.setAttribute('data-bs-theme', savedTheme);
            })();
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>

    <main class="d-flex flex-nowrap w-100">
        
        <aside class="d-flex flex-column flex-shrink-0 p-3 bg-body-tertiary no-transition" id="sidebar">
            <a href="/" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto link-body-emphasis text-decoration-none justify-content-start">
                <i class="bi bi-kanban pe-none me-2 fs-3 text-primary"></i>
                <span class="fs-4 brand-text">Ticket System</span>
            </a>
            <hr />
            
            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item">
                    <a asp-controller="Home" asp-action="Dashboard" class="nav-link d-flex align-items-center" aria-current="page" title="Dashboard" data-bs-toggle="tooltip" data-bs-placement="right">
                        <i class="bi bi-speedometer2 pe-none me-3 fs-5"></i>
                        <span class="sidebar-text">Dashboard</span>
                    </a>
                </li>
                <li class="nav-item mt-1">
                    <a asp-controller="Ticket" asp-action="Index" class="nav-link link-body-emphasis d-flex align-items-center" title="Tickets" data-bs-toggle="tooltip" data-bs-placement="right">
                        <i class="bi bi-ticket pe-none me-3 fs-5"></i>
                        <span class="sidebar-text">Tickets</span>
                    </a>
                </li>
                <li class="nav-item mt-1">
                    <a asp-controller="Project" asp-action="Index" class="nav-link link-body-emphasis d-flex align-items-center" title="Projects" data-bs-toggle="tooltip" data-bs-placement="right">
                        <i class="bi bi-boxes pe-none me-3 fs-5"></i>
                        <span class="sidebar-text">Projects</span>
                    </a>
                </li>
                <li class="nav-item mt-1">
                    <a asp-controller="Messages" asp-action="Index" class="nav-link link-body-emphasis d-flex align-items-center" title="Messages" data-bs-toggle="tooltip" data-bs-placement="right">
                        <i class="bi bi-envelope pe-none me-3 fs-5"></i>
                        <span class="sidebar-text">Messages</span>
                    </a>
                </li>

                @if (User?.IsInRole("Admin") ?? false)
                {
                    <hr class="mt-3" />
                    <li class="nav-item">
                        <a asp-controller="ProjectManagement" asp-action="Index" class="nav-link link-body-emphasis d-flex align-items-center" title="Manage Projects" data-bs-toggle="tooltip" data-bs-placement="right">
                            <i class="bi bi-folder pe-none me-3 fs-5"></i>
                            <span class="sidebar-text">Manage Projects</span>
                        </a>
                    </li>
                    <li class="nav-item mt-1">
                        <a asp-controller="Users" asp-action="Index" class="nav-link link-body-emphasis d-flex align-items-center" title="Manage Users" data-bs-toggle="tooltip" data-bs-placement="right">
                            <i class="bi bi-people pe-none me-3 fs-5"></i>
                            <span class="sidebar-text">Manage Users</span>
                        </a>
                    </li>
                }
            </ul>

            <hr />

            <div class="dropdown">
                <a href="#" class="d-flex align-items-center link-body-emphasis text-decoration-none dropdown-toggle w-100"
                       data-bs-toggle="dropdown"
                       data-bs-boundary="viewport"
                       aria-expanded="false">
                    <div class="avatar-circle me-2">@(!string.IsNullOrEmpty(User?.Identity?.Name) ? User?.Identity?.Name.Substring(0, 1).ToUpper() : "U")</div>
                    <strong class="sidebar-text text-truncate">@(User?.Identity?.Name ?? "User")</strong>
                </a>
                <ul class="dropdown-menu text-small shadow">
                    <li><h6 class="dropdown-header">Hello, @User?.Identity?.Name</h6></li>
                    <li>
                        <a class="dropdown-item" asp-controller="Account" asp-action="Profile">Profile</a>
                    </li>
                    <li><hr class="dropdown-divider" /></li>
                    <li>
                        <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">Sign out</a>
                    </li>
                </ul>
            </div>
        </aside>

        <div class="d-flex flex-column flex-grow-1 overflow-hidden bg-body">
            
            <header class="d-flex justify-content-between align-items-center p-3 border-bottom bg-body-tertiary">
                <button class="btn btn-outline-secondary border-0 header-btn" id="sidebarToggle">
                    <i class="bi bi-list fs-4"></i>
                </button>

                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-outline-secondary border-0 rounded-circle header-btn" id="themeToggle">
                        <i class="bi bi-moon fs-5" id="themeIcon"></i>
                    </button>

                    @await Component.InvokeAsync("NotificationBadge")

                    <div class="vr mx-1" style="height: 32px; align-self: center;"></div>

                    <div class="dropdown">
                        <div class="d-flex align-items-center" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer;">
                            <div class="avatar-circle me-2 shadow-sm">@(!string.IsNullOrEmpty(User?.Identity?.Name) ? User?.Identity?.Name.Substring(0, 1).ToUpper() : "U")</div>
                            <strong class="d-none d-md-block">@(User?.Identity?.Name ?? "User")</strong>
                            <i class="bi bi-chevron-down ms-2 small text-muted"></i>
                        </div>
            
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li><h6 class="dropdown-header">Hello, @User?.Identity?.Name</h6></li>
                            <li>
                                <a class="dropdown-item py-2" asp-controller="Account" asp-action="Profile"> <i class="bi bi-person me-2"></i> Profile</a>
                            </li>
@*                             <li><a class="dropdown-item py-2" href="#"><i class="bi bi-gear me-2"></i> Settings</a></li> *@
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <a class="dropdown-item text-danger py-2" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-2"></i> Sign out
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </header>

            <div class="scrollarea p-4">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </div>
        </div>

    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    
    <script>
        document.addEventListener("DOMContentLoaded", function () {
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl, {
        trigger: 'hover' // Evita que o tooltip fique preso após clicar
        })
        });
        });
    </script>

    <script>
        const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .build();

        connection.on("ReceiveNotification", function (unreadCount) {
        const badge = document.querySelector(".bi-bell").nextElementSibling;
        if(badge) {
        badge.innerText = unreadCount;
        badge.style.display = unreadCount > 0 ? "inline-block" : "none";
        }
        });

        connection.on("ReceiveMessage", function (senderId, messageContent) {
        if (typeof handleIncomingMessage === "function") {
        handleIncomingMessage(senderId, messageContent);
        }
        });
    
        connection.on("UserPresenceChanged", function (userId, isOnline) {
        const statusBadge = document.getElementById(`status-users-${userId}`);
        if (statusBadge) {
        if (isOnline) {
        statusBadge.classList.remove('bg-secondary');
        statusBadge.classList.add('bg-success');
        statusBadge.innerText = "Online";
        } else {
        statusBadge.classList.remove('bg-success');
        statusBadge.classList.add('bg-secondary');
        statusBadge.innerText = "Offline";
        }
        }

        const chatIndicator = document.querySelector(`[data-user-id='${userId}'] .online-indicator`);
        if (chatIndicator) {
        if (isOnline) {
        chatIndicator.classList.remove('bg-secondary');
        chatIndicator.classList.add('bg-success');
        } else {
        chatIndicator.classList.remove('bg-success');
        chatIndicator.classList.add('bg-secondary');
        }
        }
        });

        connection.start().catch(function (err) {
        return console.error(err.toString());
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>