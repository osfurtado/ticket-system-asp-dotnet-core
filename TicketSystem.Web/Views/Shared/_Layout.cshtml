<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TicketSystem</title>
    <script>
            (function () {
                const savedTheme = localStorage.getItem('theme') || 'light';
                document.documentElement.setAttribute('data-bs-theme', savedTheme);
            })();
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>

    <aside class="sidebar" id="sidebar">
        <div class="brand-title">
            <i class="bi bi-kanban text-primary me-2 fs-3"></i>
            <span class="sidebar-text">Ticket System</span>
        </div>
        
        <nav class="nav flex-column mt-3">
            <a asp-controller="Home" asp-action="LoginOnly" class="nav-link active">
                <i class="bi bi-speedometer2"></i> <span class="sidebar-text">Dashboard</span>
            </a>
            <a asp-controller="Ticket" asp-action="Index" class="nav-link">
                <i class="bi bi-ticket"></i> <span class="sidebar-text">Tickets</span>
            </a>
            <a asp-controller="Project" asp-action="Index" class="nav-link">
                <i class="bi bi-boxes"></i> <span class="sidebar-text">Projects</span>
            </a>
            <a asp-controller="Messages" asp-action="Index" class="nav-link">
                <i class="bi bi-envelope"></i> <span class="sidebar-text">Messages</span>
            </a>

            @if (User?.IsInRole("Admin") ?? false)
            {
                <hr class="text-secondary mx-3" />
                <div class="sidebar-text px-3 mb-1 text-uppercase text-muted small">Admin</div>
                
                <span class="nav-link">
                    <i class="bi bi-shield-lock"></i> <span class="sidebar-text">Admin Panel</span>
                </span>
                <a asp-controller="ProjectManagement" asp-action="Index" class="nav-link">
                    <i class="bi bi-folder"></i> <span class="sidebar-text">Manage Projects</span>
                </a>
                <a asp-controller="Users" asp-action="Index" class="nav-link">
                    <i class="bi bi-people"></i> <span class="sidebar-text">Manage Users</span>
                </a>
            }
        </nav>
        
        <div class="mt-auto mb-3">
            <a asp-controller="Account" asp-action="Logout" class="nav-link text-danger">
                <i class="bi bi-box-arrow-left"></i> <span class="sidebar-text">Logout</span>
            </a>
        </div>
    </aside>

    <div class="main-wrapper">
        
        <header class="top-header">
            <button class="btn btn-outline-secondary border-0" id="sidebarToggle">
                <i class="bi bi-list fs-4"></i>
            </button>

            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-outline-secondary border-0 rounded-circle" id="themeToggle">
                    <i class="bi bi-moon fs-5" id="themeIcon"></i>
                </button>

                <button class="btn btn-outline-secondary border-0 rounded-circle position-relative">
                    <i class="bi bi-bell fs-5"></i>
                    <span class="position-absolute top-25 start-70 translate-middle badge rounded-pill bg-danger">
                        3 <span class="visually-hidden">unread messages</span>
                    </span>
                </button>

                <!-- USER AVATAR -->
                @{
                    var userName = User?.Identity?.Name;
                    var initial = !string.IsNullOrEmpty(userName) ? userName.Substring(0, 1).ToUpper() : "U";
                }
                <div class="dropdown">
                    <!-- O Avatar agora atua como o botão (trigger) -->
                    <div class="user-avatar dropdown-toggle"
                         role="button"
                         id="dropdownMenuAvatar"
                         data-bs-toggle="dropdown"
                         aria-expanded="false"
                         title="@userName"
                         style="cursor: pointer;">
                        @initial
                    </div>

                    <!-- O Menu -->
                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dropdownMenuAvatar">
                        <li>
                            <a class="dropdown-item d-flex align-items-center" href="#">
                                <i class="bi bi-person me-2"></i> Profile
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item d-flex align-items-center text-danger" asp-controller="Account" asp-action="Logout">
                                <i class="bi bi-box-arrow-right me-2"></i> Logout
                            </a>
                        </li>
                    </ul>
                </div>

            </div>
        </header>

        <main class="content-area">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .build();

        connection.on("ReceiveNotification", function (unreadCount) {
        // Update the bell icon notification badge globally
        const badge = document.querySelector(".bi-bell").nextElementSibling;
        if(badge) {
        badge.innerText = unreadCount;
        badge.style.display = unreadCount > 0 ? "inline-block" : "none";
        }
        });

        connection.on("ReceiveMessage", function (senderId, messageContent) {
        // If the user is currently on the Messages page and chatting with senderId,
        // append the message to the chat window.
        // Otherwise, update the unread count on the conversation list.
        if (typeof handleIncomingMessage === "function") {
        handleIncomingMessage(senderId, messageContent);
        }
        });
    
        connection.on("UserPresenceChanged", function (userId, isOnline) {
        // Update the green indicator dot dynamically in the UI
        const userElement = document.querySelector(`[data-user-id='${userId}'] .online-indicator`);
        if (userElement) {
        userElement.classList.toggle('bg-success', isOnline);
        userElement.classList.toggle('bg-secondary', !isOnline);
        }
        });

        connection.start().catch(function (err) {
        return console.error(err.toString());
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>