@using TicketSystem.Web.Models.Ticket.ViewModels
@model TicketEditViewModel

@{
}

<form asp-controller="Ticket" asp-action="Edit" asp-route-id="@Model.Id" method="post" class="ajax-modal-form">
    <div class="modal-header">
        <h5 class="modal-title" id="editTicketModalLabel">Update ticket</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>
    <div class="modal-body">
        <div class="mb-3">
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="CurrentStatus" class="form-label"></label>
            <select asp-for="CurrentStatus" asp-items="Model.StatusList" class="form-select" disabled="@(!Model.CanChangeStatus ? "disabled" : null)">
                <option value="">-- Select Status --</option>
            </select>
            <span asp-validation-for="CurrentStatus" class="text-danger"></span>
            @if (!Model.CanChangeStatus)
            {
                <small class="text-danger">This ticket is blocked or not assigned.</small>
                <input type="hidden" asp-for="CurrentStatus" />
            }
        </div>
        <div class="mb-3">
            <label asp-for="AssigneeId" class="form-label"></label>
            <select asp-for="AssigneeId" asp-items="Model.UsersList" class="form-select">
                <option value="">-- Unassigned --</option>
            </select>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Ticket</button>
    </div>
</form>