@using TicketSystem.Web.Models.Ticket.ViewModels
@model TicketAddDependencyViewModel

@{
}

<h6 class="mb-2 mt-4 text-secondary fs-6">
    Blocked By:
</h6>

@if (Model.TicketsBlockingMe.Any())
{
    <ul class="list-group mb-4">
        @foreach (var blocker in Model.TicketsBlockingMe)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center list-group-item-light">
                <div class="d-flex gap-2 align-items-center">
                    <!-- Button to Remove Dependency -->
                    <form asp-controller="Ticket" asp-action="RemoveDependency" method="post" class="m-0">
                        <input type="hidden" name="blockedId" value="@Model.BlockedTicketId" />
                        <input type="hidden" name="blockingId" value="@blocker.Id" />
                        <button type="submit" class="btn border-0 bg-transparent p-0 text-danger" title="Remove Block">
                            <i class="bi bi-x-circle"></i>
                        </button>
                    </form>
                    <a asp-action="Details" asp-route-id="@blocker.Id" class="text-decoration-none">
                        #@blocker.Id - @blocker.Title
                    </a>
                    <span class="ms-2 badge bg-secondary">@blocker.CurrentStatus</span>
                </div>
            </li>
        }
    </ul>
}
else
{
    <div class="alert alert-light d-flex align-items-center mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        <div>This Ticket is not being blocked!.</div>
    </div>
}

@if (Model.TicketsIBlock.Any())
{
    <h5 class="mb-2 mt-4 text-secondary fs-6">
        Blocking:
    </h5>
    <ul class="list-group mb-4 ">
        @foreach (var blocked in Model.TicketsIBlock)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center list-group-item-light">
                <div>
                    <a asp-action="Details" asp-route-id="@blocked.Id" class="text-decoration-none">
                        #@blocked.Id - @blocked.Title
                    </a>
                </div>
            </li>
        }
    </ul>
}

<hr class="my-4" />

<div class="card shadow-sm">
    <div class="card-header bg-light-subtle bg-opacity-25 fw-bold">
        <i class="bi bi-link-45deg"></i> Add new blocker
    </div>
    <div class="card-body">
        <form asp-controller="Ticket" asp-action="AddDependency" method="post" id="formAddDependency">
            <input type="hidden" asp-for="BlockedTicketId" />

            <div class="row gx-3 align-items-start text-sm">
                <div class="col-md-9">
                    <select asp-for="BlockingTicketId" asp-items="Model.AvailableTickets" class="form-select searchable-select" required>
                        <option value="">Search for Ticket Id or Title...</option>
                    </select>
                    <span asp-validation-for="BlockingTicketId" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="col-md-3 mt-3 mt-md-0 d-flex align-items-end">
                    <button type="submit" class="btn btn-success btn-sm w-100" id="btnSubmitDependency">
                        Add
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>
