@using TicketSystem.Web.Models.Project
@model ProjectBoardViewModel

<div class="container-fluid mt-2">
    <div class="d-flex gap-2 align-items-center">
        <a asp-action="Index" class="btn btn-success"> <i class="bi bi-chevron-left"></i>All</a>
        <h2>
            @Model.ProjectTitle
        </h2>
    </div>
    <div class="d-flex justify-content-between mt-2 mb-4">
        <div>
            @if (Model.EndDate.HasValue)
            {
                <span class="text-muted">Ended at: @Model.EndDate</span>
            }
        </div>
        @if (!Model.EndDate.HasValue)
        {
            <div class="d-flex gap-2">
                @if (Model.CanManage)
                {
                    <a class="btn btn-primary btn-sm" asp-controller="ProjectManagement" asp-action="Details" asp-route-id="@Model.ProjectId"><i class="bi bi-gear"></i> Manage</a>
                }
                
                   @* TODO: MOVE TO PROJECT MANAGEMENT *@
              @*<form asp-controller="Project" asp-action="Close" asp-route-id="@Model.ProjectId" method="post"
                      onsubmit="return confirm('Would you like to finish this Project? It will not be possible to add new tickets.');">
                    <button type="submit" class="btn btn-outline-danger">
                        Finish Project
                    </button>
                </form> *@

                @if (Model.CanCreateTicket)
                {
                    <button type="button" class="btn btn-success btn-sm" onclick="openCreateModal(@Model.ProjectId)">
                        <i class="bi bi-plus-lg"></i> New Ticket
                    </button>
                }
            </div>
        }
    </div>
   
    <!-- KANBAN BOARD -->
    <div class="row flex-nowrap overflow-auto pb-4" style="min-height: 60vh;">
        @foreach (var status in Model.WorkflowStatuses)
        {
            <div class="col-12 col-md-4 col-lg-3 kanban-column"
                 ondragover="allowDrop(event)"
                 ondrop="drop(event, this)"
                 data-status="@status">
            
                <div class="bg-secondary-subtle rounded-3 p-3 h-100 d-flex flex-column">
                    <h6 class="text-uppercase text-muted mb-3">
                        @status
                        <span class="badge bg-secondary rounded-pill float-end status-count">
                            @Model.Tickets.Count(t => t.CurrentStatus == status)
                        </span>
                    </h6>

                    <div class="d-flex flex-column gap-2 flex-grow-1 dropzone">
                        @foreach (var ticket in Model.Tickets.Where(t => t.CurrentStatus == status))
                        {
                            bool canDrag = !ticket.IsLocked;
                            <div class="card shadow-sm border-start border-1 @(ticket.IsBlocked ? "border-danger" : "border-primary") kanban-card @(canDrag ? "" : "opacity-75")"
                                 draggable="@(canDrag ? "true" : "false")"
                                 ondragstart="@(canDrag ? "drag(event)" : "return false;")"
                                 id="ticket-@ticket.Id"
                                 data-ticket-id="@ticket.Id">
     
                                <div class="card-body p-2" style="@(canDrag ? "cursor: grab;" : "cursor: not-allowed;")">
                                    <div class="d-flex justify-content-between mb-1">
                                        <small class="text-muted">#@ticket.Id</small>
                                    </div>
                                    <h6 class="card-title mb-2" style="font-size: 0.95rem;">@ticket.Title</h6>
        
                                    <div class="d-flex justify-content-between align-items-center mt-3">
                                        <div class="text-muted small">
                                            <div class="badge bg-info text-dark rounded-circle me-2" title="@ticket.AssigneeName" style="width: 25px; height: 25px; display: inline-flex; align-items: center; justify-content: center;">
                                                @(string.IsNullOrEmpty(ticket.AssigneeName) ? "?" : ticket.AssigneeName.Substring(0, 1).ToUpper())
                                            </div>
                                        </div>
                                        <div class="btn-group">
                                            <a asp-controller="Ticket"
                                                   asp-action="Details"
                                                   asp-route-id="@ticket.Id"
                                                   class="btn btn-sm btn-outline-secondary"
                                                   title="See Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                
                                            @if (ticket.CanAssign)
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-primary" title="Assign to"
                                                        onclick="openEditModal(@ticket.Id)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
    
   @* -- Create Ticket Modal -- *@
    <div class="modal fade" id="createTicketModal" tabindex="-1" aria-labelledby="createTicketModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" id="createModalContent">
                <!-- Create Ticket Partial View -->
            </div>
        </div>
    </div>

    <!-- Ticket Edit Modal -->
    <div class="modal fade" id="editTicketModal" tabindex="-1" aria-labelledby="editTicketModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" id="editModalContent">
                <!-- Partial View: _EditTicketModalPartial -->
            </div>
        </div>
    </div>
    
   @* -- Assign Ticket Modal -- *@
    <div class="modal fade" id="assignTicketModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content" id="assignModalContent">
                <!-- Partial View -->
            </div>
        </div>
    </div>
</div>
@Html.AntiForgeryToken()

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // -- CREATE TICKET MODAL SCRIPT --
        function openCreateModal(projectId = null) {

            var url = '@Url.Action("CreatePartial", "Ticket")';

            if (projectId) {
                url += '?projectId=' + projectId;
            }

            $.get(url, function (data) {
                $('#createModalContent').html(data);
                $('#createTicketModal').modal('show');
                
                // Re-bind ASP.NET client-side validation for the injected form
                $.validator.unobtrusive.parse('#createModalContent form');
            });
        }

         // -- CREATE TICKET MODAL SCRIPT --
        function openEditModal(id) {
            $.get('@Url.Action("EditPartial", "Ticket")/' + id, function (data) {
                $('#editModalContent').html(data);
                $('#editTicketModal').modal('show');
                
                $.validator.unobtrusive.parse('#editModalContent form');
            });
        }

        // -- ASSIGN MODAL SCRIPT --
        function openAssignModal(ticketId) {
            $.get('@Url.Action("AssignPartial", "Ticket")/' + ticketId, function (data) {
                $('#assignModalContent').html(data);
                $('#assignTicketModal').modal('show');
                
                $.validator.unobtrusive.parse('#assignModalContent form');
            });
        }

        // Event delegation because the forms are injected dynamically
        $(document).on('submit', '.ajax-modal-form', function (e) {
            e.preventDefault(); // Stop standard full-page submission
            
            var form = $(this);
            var modalContentId = form.closest('.modal-content').attr('id');

            $.ajax({
                url: form.attr('action'),
                type: form.attr('method'),
                data: form.serialize(),
                success: function (response) {
                    if (response.success) {
                        // Success: Close modal and refresh the page to show new data
                        // (This keeps your current URL filters intact!)
                        location.reload();
                    } else {
                        // Validation Failed: The controller returned the Partial View HTML with error messages.
                        // We replace the modal content with this new HTML.
                        $('#' + modalContentId).html(response);
                        $.validator.unobtrusive.parse('#' + modalContentId + ' form');
                    }
                },
                error: function () {
                    alert("An error occurred while saving. Please try again.");
                }
            });
        });


        // -- KANBAN SCRIPT --
        function allowDrop(ev) {
            ev.preventDefault();
        }

        let originalParent = null;

        function drag(ev) {
            ev.dataTransfer.setData("cardId", ev.currentTarget.id);
            originalParent = ev.currentTarget.parentNode;
        }

        function allowDrop(ev) {
            ev.preventDefault();
        }

        function drop(ev, columnElement) {
            ev.preventDefault();
    
            var cardId = ev.dataTransfer.getData("cardId");
            var cardElement = document.getElementById(cardId);
            var dropzone = columnElement.querySelector('.dropzone');
    
            // Se soltar na mesma coluna de onde saiu, não faz nada
            if (originalParent === dropzone) return;

            // 1. Move visualmente (para dar a sensação de fluidez)
            dropzone.appendChild(cardElement);

            var ticketId = cardElement.getAttribute('data-ticket-id');
            var newStatus = columnElement.getAttribute('data-status');
            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch('/Ticket/UpdateStatus', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ TicketId: parseInt(ticketId), NewStatus: newStatus })
            })
            .then(response => {
                if (!response.ok) throw new Error(`Error HTTP: ${response.status}`);
                return response.json();
            })
            .then(data => {
                if (data.success) {
                    // === INÍCIO DA ATUALIZAÇÃO DOS CONTADORES ===
        
                    // 1. Encontra a coluna de origem e a coluna de destino
                    let sourceColumn = originalParent.closest('.kanban-column');
                    let targetColumn = columnElement;

                    // 2. Encontra os badges (contadores) dentro dessas colunas
                    let sourceBadge = sourceColumn.querySelector('.status-count');
                    let targetBadge = targetColumn.querySelector('.status-count');

                    // 3. Atualiza os números (subtrai 1 da origem, soma 1 no destino)
                    if (sourceBadge && targetBadge) {
                        sourceBadge.innerText = parseInt(sourceBadge.innerText) - 1;
                        targetBadge.innerText = parseInt(targetBadge.innerText) + 1;
                    }
        
                    // === FIM DA ATUALIZAÇÃO DOS CONTADORES ===
                } else {
                    alert(data.message);
                    // Falhou na regra de negócio (ex: não tem Assignee), reverte o card
                    originalParent.appendChild(cardElement);
                }
            })
            .catch(error => {
                console.error(error);
                alert("Errr while updating status!");
                // Deu erro de servidor, reverte o card
                originalParent.appendChild(cardElement);
            });
        }
    </script>
}