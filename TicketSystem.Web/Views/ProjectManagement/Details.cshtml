@model TicketSystem.Web.Models.ProjectManagement.ProjectDetailsViewModel

@* @{
    ViewData["Title"] = "Details";
} *@

<div class="container mt-1">
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-success"><i class="bi bi-chevron-left"></i> All</a>
        <h3 class="mb-0">Project: @Model.Title</h3>
    </div>
    <ul class="nav nav-tabs mt-2" id="myTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="home-tab" data-bs-toggle="tab" data-bs-target="#home" type="button" role="tab" aria-controls="home" aria-selected="true">Home</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="members-tab" data-bs-toggle="tab" data-bs-target="#members" type="button" role="tab" aria-controls="members" aria-selected="false">
                Members
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="workflow-tab" data-bs-toggle="tab" data-bs-target="#workflow" type="button" role="tab" aria-controls="workflow" aria-selected="false">Workflow</button>
        </li>
    </ul>

    <div class="tab-content mt-3" id="myTabContent">
        <!-- HOME TAB -->
        <div class="tab-pane fade show active" id="home" role="tabpanel" aria-labelledby="home-tab">
            <div class="row">
                <div class="col-lg-8">
                    <div class="d-flex gap-2 my-3">
                        <div class="card text-center shadow-sm" style="width: 18rem;">
                            <div class="card-body">
                                <h2 class="display-4 fw-bold mb-0">@Model.TotalTickets</h2>
                                <p class="text-muted text-uppercase small">Tickets</p>
                            </div>
                        </div>
                        <div class="card text-center shadow-sm" style="width: 18rem;">
                            <div class="card-body">
                                <h2 class="display-4 fw-bold mb-0">@Model.ExistingMembers.Count()</h2>
                                <p class="text-muted text-uppercase small">Members</p>
                            </div>
                        </div>
                    </div>
                    <div class="card mb-3 shadow-sm">
                        <div class="card-header bg-light-subtle">
                            <h5 class="mb-0">Description</h5>
                        </div>
                        <div class="card-body">
                            <p class="card-text mt-3" style="white-space: pre-wrap;">@Model.Description</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 mt-4 mt-lg-0">
                    <div class="card mb-4 shadow-sm">
                        <div class="card-header bg-light-subtle">
                            <h5 class="mb-0">Details</h5>
                        </div>
                        <div class="card-body">
                            <ul class="list-unstyled mb-0">
                                <li class="mb-2">
                                    <span class="text-muted d-block small">Created By</span>
                                    <span>@Model.CreatedByName</span>
                                </li>
                                <li>
                                    <span class="text-muted d-block small">Start</span>
                                    <span>@Model.StartDate.ToString("dd/MM/yyyy")</span>
                                </li>
                                <li>
                                    <span class="text-muted d-block small">End</span>
                                    <span>@Model.EndDate?.ToString("dd/MM/yyyy")</span>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- MEMBERS TAB -->
        <div class="tab-pane fade" id="members" role="tabpanel" aria-labelledby="members-tab">
            <div class="col">
                <div class="col-md-6">
                    <div class="d-flex justify-content-between gap-3 mt-4 mb-3">
                        <h5>List of Members</h5>
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#inviteModal">
                                <i class="bi bi-link-45deg"></i> Invite Link
                            </button>
                            <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addMemberModal"><i class="bi bi-plus-lg"></i> Add Member</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                        @foreach (var member in Model.ExistingMembers)
                        {
                            <div class="list-group-item list-group-item-action d-flex align-items-center p-2 border-start-0 border-end-0 border-top-0">
                    
                                <!-- Avatar -->
                                <div class="avatar-circle me-3 flex-shrink-0">
                                    @member.Initials
                                </div>
                    
                                <!-- Member Name & Shield -->
                                <div class="d-flex gap-2 align-items-center flex-grow-1 min-width-0">
                                    <h6 class="mb-0 text-truncate">@member.MemberName</h6>
                        
                                    @if (member.RoleInProject == "Manager")
                                    {
                                        <i class="bi bi-shield-fill text-primary flex-shrink-0" title="Manager"></i>
                                    }
                                </div>

                                <!-- Dropdown Menu -->
                            @if (member.MemberId != Model.CurrentUserId)
                            {
                                <div class="dropdown flex-shrink-0">
                                    <button class="btn btn-sm btn-link text-muted p-1" type="button" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow">
                                        <li>
                                            <form asp-action="ChangeMemberRole" method="post">
                                                <input type="hidden" name="projectId" value="@Model.ProjectId" />
                                                <input type="hidden" name="memberId" value="@member.MemberId" />
                                                <input type="hidden" name="newRole" value="@(member.RoleInProject == "Manager" ? "Member" : "Manager")" />
                                                <button type="submit" class="dropdown-item btn-sm text-sm">
                                                    @(        member.RoleInProject == "Manager" ? "Demote to Member" : "Promote to Manager")
                                                </button>
                                            </form>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form asp-action="RemoveMember" method="post">
                                                <input type="hidden" name="projectId" value="@Model.ProjectId" />
                                                <input type="hidden" name="memberId" value="@member.MemberId" />
                                                <button type="submit" class="dropdown-item text-danger btn-sm text-sm">Remove Member</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            }
                            else
                            {
                                <div class="flex-shrink-0" style="width: 28px;"></div>
                            }
                        </div>
                        }
                </div>
            </div>
        </div>
        
        <!-- WORKFLOW TAB -->
        <div class="tab-pane fade" id="workflow" role="tabpanel" aria-labelledby="workflow-tab">
            <h5 class="mt-4 mb-3">Statuses</h5>
            <div class="card shadow-sm col-lg-6">
                <div class="card-header">
                    <h6 class="mb-0">Workflow Steps</h6>
                </div>
    
                <div class="list-group list-group-flush">
        
                    <!-- FIXED START -->
                    <div class="list-group-item bg-light-subtle text-muted d-flex align-items-center p-3">
                        <i class="bi bi-play-circle-fill text-success me-3 fs-5"></i>
                        <div class="flex-grow-1">
                            <h6 class="mb-0">Open</h6>
                            <small>Initial Status (System Locked)</small>
                        </div>
                    </div>

                    <!-- DRAGGABLE MIDDLE STATUSES -->
                    <!-- We give this div an ID so our JavaScript can make it sortable -->
                    <div id="sortable-statuses">
                        @foreach (var status in Model.WorkflowStatuses.Where(s => !s.IsInicial && !s.IsFinal).OrderBy(s => s.OrderIndex))
                        {
                            <div class="list-group-item d-flex align-items-center p-3" data-status-id="@status.StatusId">
                                <!-- Drag Handle -->
                                <i class="bi bi-grip-vertical text-muted me-3 cursor-grab" style="cursor: grab;"></i>
                    
                                <div class="flex-grow-1">
                                    <h6 class="mb-0">@status.Name</h6>
                                </div>

                                <!-- Delete Action -->
                                <form asp-action="RemoveWorkflowStatus" method="post" class="m-0">
                                    <input type="hidden" name="projectId" value="@Model.ProjectId" />
                                    <input type="hidden" name="statusId" value="@status.StatusId" />
                                    <button type="submit" class="btn btn-sm btn-link text-danger shadow-none p-0" title="Remove">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        }
                    </div>

                    <!-- INLINE ADD NEW STATUS -->
                    <div class="list-group-item p-3 border-top-0">
                        <form asp-action="AddWorkflowStatus" method="post" class="d-flex gap-2">
                            <input type="hidden" name="WorkflowId" value="@Model.WorkflowId" />
                            <input type="hidden" name="ProjectId" value="@Model.ProjectId" />
                            <input type="text" name="Name" class="form-control form-control-sm" placeholder="Type new status name..." required />
                            <button type="submit" class="btn btn-sm btn-primary text-nowrap">Add Step</button>
                        </form>
                    </div>

                    <!-- FIXED END -->
                    <div class="list-group-item bg-light-subtle text-muted d-flex align-items-center p-3">
                        <i class="bi bi-stop-circle-fill text-secondary me-3 fs-5"></i>
                        <div class="flex-grow-1">
                            <h6 class="mb-0">Closed</h6>
                            <small>Final Status (System Locked)</small>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>


<!-- MEMBERS TAB - Modals  -->
<div class="modal fade" id="addMemberModal" tabindex="-1" aria-labelledby="addMemberModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addMemberModalLabel">Add new Member</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="AddMember" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
                    <input type="hidden" name="ProjectId" value="@Model.AddMemberForm.ProjectId" />
                    <div class="mb-3">
                        <label asp-for="AddMemberForm.SelectedUserId" class="form-label"></label>
                        <select name="SelectedUserId" class="form-select" asp-items="Model.AddMemberForm.AvailableUsers">
                            <option value="">-- Select Member --</option>
                        </select>
                        <span asp-validation-for="AddMemberForm.SelectedUserId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="AddMemberForm.SelectedRole" class="form-label"></label>
                        <select name="SelectedRole" class="form-select" asp-items="Model.AddMemberForm.AvailableRoles">
                            <option value="">-- Select Role --</option>
                        </select>
                        <span asp-validation-for="AddMemberForm.SelectedRole" class="text-danger"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>
<div class="modal fade" id="inviteModal" tabindex="-1" aria-labelledby="inviteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="inviteModalLabel">Invite to Project</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p class="text-muted mb-4">Generate a link to share with others. Anyone with this link can join the project as a Member.</p>
                
                <!-- This form is used to securely POST the request -->
                <form id="generateLinkForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="inviteProjectId" value="@Model.ProjectId" />
                    <button type="submit" class="btn btn-primary mb-3" id="generateLinkBtn">
                        Generate Link
                    </button>
                </form>

                <!-- Hidden by default, shown when the link is generated -->
                <div id="linkContainer" class="d-none">
                    <div class="input-group mb-3">
                        <input type="text" id="inviteUrlInput" class="form-control" readonly>
                        <button class="btn btn-outline-secondary" type="button" id="copyLinkBtn" title="Copy to clipboard">
                            <i class="bi bi-clipboard"></i>
                        </button>
                    </div>
                    <span id="copySuccessMsg" class="text-success small d-none"><i class="bi bi-check-circle"></i> Copied to clipboard!</span>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let hash = window.location.hash;
            if (hash) {
                let triggerEl = document.querySelector('button[data-bs-target="' + hash + '"]');
                if (triggerEl) {
                    let tab = new bootstrap.Tab(triggerEl);
                    tab.show();
                }
            }
            let tabElements = document.querySelectorAll('button[data-bs-toggle="tab"]');
            tabElements.forEach(function (tabEl) {
                tabEl.addEventListener('shown.bs.tab', function (event) {
                    let target = event.target.getAttribute("data-bs-target");
                    history.replaceState(null, null, target);
                });
            });

            // --- INVITE LINK LOGIC ---
            const generateForm = document.getElementById('generateLinkForm');
            const generateBtn = document.getElementById('generateLinkBtn');
            const linkContainer = document.getElementById('linkContainer');
            const inviteUrlInput = document.getElementById('inviteUrlInput');
            const copyLinkBtn = document.getElementById('copyLinkBtn');
            const copySuccessMsg = document.getElementById('copySuccessMsg');

            // 1. Generate the Link
            generateForm.addEventListener('submit', async function (e) {
                e.preventDefault();
                
                const projectId = document.getElementById('inviteProjectId').value;
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                // Create FormData to send the AntiForgeryToken and ProjectId
                const formData = new FormData();
                formData.append('projectId', projectId);
                formData.append('__RequestVerificationToken', token);

                try {
                    // Disable button and show loading state
                    generateBtn.disabled = true;
                    generateBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Generating...';

                    const response = await fetch('@Url.Action("GenerateInviteLink", "ProjectManagement")', {
                        method: 'POST',
                        body: formData
                    });

                    const data = await response.json();

                    if (data.success) {
                        // Populate the input and show the container
                        inviteUrlInput.value = data.url;
                        linkContainer.classList.remove('d-none');
                        generateBtn.innerHTML = 'Regenerate Link'; // Change text for subsequent uses
                    } else {
                        alert("Error generating link.");
                    }
                } catch (error) {
                    console.error("Error:", error);
                    alert("An error occurred while generating the link.");
                } finally {
                    generateBtn.disabled = false;
                }
            });

            // 2. Copy to Clipboard
            copyLinkBtn.addEventListener('click', function () {
                // Use the Clipboard API
                navigator.clipboard.writeText(inviteUrlInput.value).then(() => {
                    // Change icon to a checkmark temporarily
                    copyLinkBtn.innerHTML = '<i class="bi bi-check2"></i>';
                    copyLinkBtn.classList.replace('btn-outline-secondary', 'btn-success');
                    copySuccessMsg.classList.remove('d-none');

                    // Revert back after 2 seconds
                    setTimeout(() => {
                        copyLinkBtn.innerHTML = '<i class="bi bi-clipboard"></i>';
                        copyLinkBtn.classList.replace('btn-success', 'btn-outline-secondary');
                        copySuccessMsg.classList.add('d-none');
                    }, 2000);
                }).catch(err => {
                    console.error('Failed to copy: ', err);
                });
            });

        // --- DRAG & DROP LOGIC FOR WORKFLOW STATUSES ---

        const sortableContainer = document.getElementById('sortable-statuses');
            
        if (sortableContainer) {
            new Sortable(sortableContainer, {
                animation: 150, // Smooth dragging animation
                handle: '.bi-grip-vertical', // Only drag when clicking the grip icon
                ghostClass: 'bg-light', // Class applied to the placeholder while dragging
                    
                // Triggered when the user drops the item in a new position
                onEnd: function (evt) {
                    // Gather the new order of IDs
                    let newOrder = [];
                    sortableContainer.querySelectorAll('.list-group-item').forEach((item, index) => {
                        newOrder.push({
                            Id: item.getAttribute('data-status-id'),
                            OrderIndex: index
                        });
                    });

                    // Send the new order to the MVC Controller via AJAX
                    fetch('@Url.Action("UpdateStatusOrder", "ProjectManagement")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            // Include anti-forgery token if required by your setup
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                        },
                        body: JSON.stringify(newOrder)
                    }).then(response => {
                        if(!response.ok) {
                            alert("Failed to save the new workflow order.");
                        }
                    });
                }
            });
        }
        });
    </script>
}
