@using TicketSystem.Web.Models.Users
@model IEnumerable<UserListViewModel>

@{
    ViewData["Title"] = "User Management";
}

<h2>@ViewData["Title"]</h2>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<p class="mt-3">
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-person-plus"></i> New User
    </a>
</p>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Role</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>
                    <span class="badge bg-secondary">@item.RoleName</span>
                </td>
                <td>
                    @if (item.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactive</span>
                    }
                </td>
                <td>
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                            Edit
                        </a>

                        @if (item.Id == ViewBag.CurrentUserId)
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="You cannot deactivate itself">
                                Deactivate (You)
                            </button>
                        }
                        else
                        {
                            <form asp-action="ToggleStatus" asp-route-id="@item.Id" method="post" class="m-0 p-0">
                                @if (item.IsActive)
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Tem certeza que deseja inativar este usuário?');">
                                        Deactivate
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        Activate
                                    </button>
                                }
                            </form>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>