@using TicketSystem.Web.Models.Users
@model UserManagementViewModel

@{
    ViewData["Title"] = "Manage Users";
}

<div class="my-3 d-flex justify-content-between align-items-center">
    <h2 class="h3 mb-0 text-gray-800 fw-bold">@ViewData["Title"]</h2>
    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createUserModal">
        <i class="bi bi-person-plus"></i> New User
    </button>
</div>

<!-- Users Table -->
<table class="table align-middle">
        <thead class="table-secondary">
            <tr>
                <th>Name</th>
                <th>Username</th>
                <th>Online</th>
                <th>Role</th>
                <th>Status</th>
                <th style="width: 80px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Users)
            {
                <tr>
                    <td class="d-flex align-items-center p-2">
                        <div class="avatar-circle me-3">
                            @item.Initials
                        </div>
                        <div class="text-truncate d-flex align-items-center">
                            @item.Name
                        </div>
                    </td>
                    <td>@item.Username</td>
                    <td>
                        <span id="status-users-@item.Id" class="badge @(item.IsOnline ? "bg-success" : "bg-secondary")">
                            @(item.IsOnline ? "Online" : "Offline")
                        </span>
                    <td>
                        <span class="badge bg-secondary">@item.RoleName</span>
                    </td>
                    <td>
                        <span class="badge @(item.IsActive ? "bg-success" : "bg-danger")">
                            @(item.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td>
                        <div class="d-flex justify-content-end gap-3">
                            @if (item.Id != ViewBag.CurrentUserId)
                            {
                                <a href="@Url.Action("Index", "Messages", new { targetUserId = item.Id, targetUserName = item.Name })"
                                       class="text-sm text-secondary"
                                       title="Message User">
                                    <i class="bi bi-chat-left-text fs-5"></i>
                                </a>
                            }
@*                             <a asp-action="Details" asp-route-id="@item.Id" class="text-sm text-secondary" title="View Details">
                                <i class="bi bi-eye-fill fs-5"></i>
                            </a> *@
                            <div class="dropdown">
                                <button class="btn btn-sm btn-link text-secondary text-decoration-none p-0"
                                        type="button"
                                        data-bs-toggle="dropdown"
                                        data-bs-popper-config='{"strategy":"fixed"}'
                                        aria-expanded="false">
                                    <i class="bi bi-three-dots-vertical fs-5"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow">
                                    <li>
                                        <a class="dropdown-item text-sm-start" asp-action="Edit" asp-route-id="@item.Id">
                                            <i class="bi bi-pencil-square me-2 text-primary"></i> Edit
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                    @if (item.Id != ViewBag.CurrentUserId)
                                    {
                                        <form asp-action="ToggleStatus" asp-route-id="@item.Id" method="post">
                                            <input type="hidden" name="IsActive" value="@(item.IsActive ? false : true)" />
                                            <button type="submit" class="dropdown-item btn-sm text-sm">
                                                @(item.IsActive ? "Deactivate" : "Activate")
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button disabled class="dropdown-item btn-sm text-sm">
                                            You
                                        </button>
                                    }
                                </li>
                                </ul>
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>


<!-- Create User Modal -->
<div class="modal fade" id="createUserModal" tabindex="-1" aria-labelledby="createUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="createUserModalLabel">Create New User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                    <div class="mb-3">
                        <label asp-for="CreateForm.Name" class="form-label"></label>
                        <input asp-for="CreateForm.Name" class="form-control" />
                        <span asp-validation-for="CreateForm.Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CreateForm.Username" class="form-label"></label>
                        <input asp-for="CreateForm.Username" class="form-control" />
                        <span asp-validation-for="CreateForm.Username" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CreateForm.Password" class="form-label"></label>
                        <input asp-for="CreateForm.Password" class="form-control" type="password" />
                        <span asp-validation-for="CreateForm.Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CreateForm.RoleId" class="form-label"></label>
                        <select asp-for="CreateForm.RoleId" class="form-select" asp-items="ViewBag.Roles">
                            <option value="">-- Select a Role --</option>
                        </select>
                        <span asp-validation-for="CreateForm.RoleId" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="CreateForm.IsActive" class="form-check-input" />
                        <label asp-for="CreateForm.IsActive" class="form-check-label">Active</label>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>

        </div>
    </div>
</div>

<!-- Edit User Modal -->
<div class="modal fade" id="editUserModal" tabindex="-1" aria-labelledby="editUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="editUserModalLabel">Edit User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                    <input type="hidden" asp-for="EditForm.Id" />

                    <div class="mb-3">
                        <label asp-for="EditForm.Name" class="form-label"></label>
                        <input asp-for="EditForm.Name" class="form-control" />
                        <span asp-validation-for="EditForm.Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EditForm.Username" class="form-label"></label>
                        <input asp-for="EditForm.Username" class="form-control" />
                        <span asp-validation-for="EditForm.Username" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EditForm.RoleId" class="form-label"></label>
                        <select asp-for="EditForm.RoleId" class="form-select" asp-items="ViewBag.Roles" disabled="@(ViewBag.CurrentUserId == Model.EditForm.Id)">
                            <option value="">-- Select a Role --</option>
                        </select>
                        <span asp-validation-for="EditForm.RoleId" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="EditForm.IsActive" class="form-check-input" disabled="@(ViewBag.CurrentUserId == Model.EditForm.Id)"  />
                        <label asp-for="EditForm.IsActive" class="form-check-label">Active</label>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>

        </div>
    </div>
</div>

@if (Model.ShowCreateModal)
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var modal = new bootstrap.Modal(document.getElementById('createUserModal'));
            modal.show();
        });
    </script>
}

@if (Model.ShowEditModal)
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var modal = new bootstrap.Modal(document.getElementById('editUserModal'));
            modal.show();
        });
    </script>
}

@section Scripts {
    <script>
    </script>
}