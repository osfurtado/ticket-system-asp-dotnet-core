@model IEnumerable<TicketSystem.Web.Models.Ticket.DisplayTicketViewModel>

@{
    ViewData["Title"] = "Ticket List";
}

<h2>Tickets</h2>

<div class="d-flex justify-content-end my-3">
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-lg"></i> New Ticket</a>
</div>

<div class="card mb-4 bg-light-subtle shadow-sm">
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3 align-items-end">
                
                <div class="col-md-2">
                    <label class="form-label text-muted small mb-1">Title</label>
                    <input type="text" name="searchTitle" class="form-control form-control-sm" value="@ViewData["SearchTitle"]" placeholder="Search..." />
                </div>

                <div class="col-md-2">
                    <label class="form-label text-muted small mb-1">Created At</label>
                    <input type="date" name="searchDate" class="form-control form-control-sm" value="@ViewData["SearchDate"]" />
                </div>

                <div class="col-md-2">
                    <label class="form-label text-muted small mb-1">Created By</label>
                    <select name="searchCreatedBy" class="form-select form-select-sm">
                        <option value="">All Users</option>
                        @foreach (var user in ViewBag.CreatedByList as List<string>)
                        {
                            <option value="@user" selected="@(ViewData["SearchCreatedBy"]?.ToString() == user)">@user</option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label text-muted small mb-1">Project</label>
                    <select name="searchProject" class="form-select form-select-sm">
                        <option value="">All Projects</option>
                        @foreach (var project in ViewBag.ProjectList as List<string>)
                        {
                            <option value="@project" selected="@(ViewData["SearchProject"]?.ToString() == project)">@project</option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label text-muted small mb-1">Assignee</label>
                    <select name="searchAssignee" class="form-select form-select-sm">
                        <option value="">All Assignees</option>
                        @foreach (var assignee in ViewBag.AssigneeList as List<string>)
                        {
                            <option value="@assignee" selected="@(ViewData["SearchAssignee"]?.ToString() == assignee)">@assignee</option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label text-muted small mb-1">Status</label>
                    <select name="searchStatus" class="form-select form-select-sm">
                        <option value="">All Status</option>
                        <option value="Open" selected="@(ViewData["SearchStatus"]?.ToString() == "Open")">Open</option>
                        <option value="In Progress" selected="@(ViewData["SearchStatus"]?.ToString() == "In Progress")">In Progress</option>
                        <option value="Close" selected="@(ViewData["SearchStatus"]?.ToString() == "Close")">Close</option>
                    </select>
                </div>

                <div class="col-12 mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-primary">
                        <i class="bi bi-funnel"></i> Apply Filters
                    </button>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Reset
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Title)</th>
                <th>@Html.DisplayNameFor(model => model.CreatedAt)</th>
                <th>@Html.DisplayNameFor(model => model.CreatedBy)</th>
                <th>@Html.DisplayNameFor(model => model.Project)</th>
                <th>@Html.DisplayNameFor(model => model.Assignee)</th>
                <th>@Html.DisplayNameFor(model => model.CurrentStatus)</th>
                <th style="width: 80px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Title)</td>
                    <td>@Html.DisplayFor(modelItem => item.CreatedAt)</td>
                    <td>@Html.DisplayFor(modelItem => item.CreatedBy)</td>
                    <td>@Html.DisplayFor(modelItem => item.Project)</td>
                    <td>@Html.DisplayFor(modelItem => item.Assignee)</td>
                    <td>
                        @if (item.CurrentStatus == "Open")
                        {
                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle">@item.CurrentStatus</span>
                        }
                        else if (item.CurrentStatus == "Close")
                        {
                            <span class="badge bg-success">@item.CurrentStatus</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">@item.CurrentStatus</span>
                        }
                    </td>
                    
                    <td class="text-center">
                        <div class="d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-sm text-secondary" title="View Details">
                                <i class="bi bi-eye-fill fs-5"></i>
                            </a>
                            @if (item.CanChange)
                            {
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-link text-secondary text-decoration-none p-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-three-dots-vertical fs-5"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow">
                                        <li>
                                            <a class="dropdown-item text-sm-start" asp-action="Edit" asp-route-id="@item.Id">
                                                <i class="bi bi-pencil-square me-2 text-primary"></i> Update
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item text-danger text-sm-start" asp-action="Delete" asp-route-id="@item.Id">
                                                <i class="bi bi-trash me-2"></i> Delete
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>