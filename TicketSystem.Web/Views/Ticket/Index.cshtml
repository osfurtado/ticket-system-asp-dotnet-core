@using TicketSystem.Web.Models.Ticket.ViewModels
@model TicketFilterViewModel

@{
    ViewData["Title"] = "Ticket List";
}

<div class="d-flex justify-content-between align-items-center my-3">
    <h2>Tickets</h2>
    <a class="btn btn-success" onclick="openCreateModal()"><i class="bi bi-plus-lg"></i> New Ticket</a>
</div>

<!-- Filter -->
<div class="card mb-4 bg-light-subtle shadow-sm">
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3 align-items-end">
                
                <div class="col-md-2">
                    <label asp-for="SearchTitle" class="form-label text-muted small mb-1">Title</label>
                    <input type="text" asp-for="SearchTitle" class="form-control form-control-sm" placeholder="Search..." />
                </div>

                <div class="col-md-2">
                    <label asp-for="SearchDate" class="form-label text-muted small mb-1">Created At</label>
                    @* The type="date" works perfectly with DateTime? properties *@
                    <input type="date" asp-for="SearchDate" class="form-control form-control-sm" />
                </div>

                <div class="col-md-2">
                    <label asp-for="SearchCreatedBy" class="form-label text-muted small mb-1">Created By</label>
                    <select asp-for="SearchCreatedBy" class="form-select form-select-sm"
                            asp-items="@(new SelectList(Model.CreatedByList))">
                        <option value="">All Users</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label asp-for="SearchProject" class="form-label text-muted small mb-1">Project</label>
                    <select asp-for="SearchProject" class="form-select form-select-sm"
                            asp-items="@(new SelectList(Model.ProjectList))">
                        <option value="">All Projects</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label asp-for="SearchAssignee" class="form-label text-muted small mb-1">Assignee</label>
                    <select asp-for="SearchAssignee" class="form-select form-select-sm"
                            asp-items="@(new SelectList(Model.AssigneeList))">
                        <option value="">All Assignees</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label asp-for="SearchStatus" class="form-label text-muted small mb-1">Status</label>
                    <select asp-for="SearchStatus" class="form-select form-select-sm">
                        <option value="">All Status</option>
                        <option value="Open">Open</option>
                        <option value="In Progress">In Progress</option>
                        <option value="Close">Closed</option>
                    </select>
                </div>

                <div class="col-12 mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-primary">
                        <i class="bi bi-funnel"></i> Apply Filters
                    </button>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Reset
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Ticket List -->
<div class="table-responsive">
    <table class="table table-hover align-middle shadow-sm">
        <thead class="table-secondary">
            <tr>
                <th>Title</th>
                <th>Created At</th>
                <th>Created By</th>
                <th>Project</th>
                <th>Assignee</th>
                <th>Status</th>
                <th style="width: 80px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Tickets)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Title)</td>
                    <td>@Html.DisplayFor(modelItem => item.CreatedAt)</td>
                    <td>@Html.DisplayFor(modelItem => item.CreatedBy)</td>
                    <td>@Html.DisplayFor(modelItem => item.Project)</td>
                    <td>@Html.DisplayFor(modelItem => item.Assignee)</td>
                    <td>
                        @if (item.CurrentStatus == "Open")
                        {
                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle">@item.CurrentStatus</span>
                        }
                        else if (item.CurrentStatus == "Close")
                        {
                            <span class="badge bg-success">@item.CurrentStatus</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">@item.CurrentStatus</span>
                        }
                    </td>
                    
                    <td class="text-center">
                        <div class="d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-sm text-secondary" title="View Details">
                                <i class="bi bi-eye-fill fs-5"></i>
                            </a>
                            @if (item.CanChange)
                            {
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-link text-secondary text-decoration-none p-0"
                                            type="button"
                                            data-bs-toggle="dropdown"
                                            data-bs-popper-config='{"strategy":"fixed"}'
                                            aria-expanded="false">
                                        <i class="bi bi-three-dots-vertical fs-5"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow">
                                        <li>
                                            <a class="dropdown-item text-sm-start" onclick="openEditModal(@item.Id)">
                                                <i class="bi bi-pencil-square me-2 text-primary"></i> Update
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item text-danger text-sm-start" asp-action="Delete" asp-route-id="@item.Id">
                                                <i class="bi bi-trash me-2"></i> Delete
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Ticket Create Modal -->
<div class="modal fade" id="createTicketModal" tabindex="-1" aria-labelledby="createTicketModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" id="createModalContent">
            <!-- Partial View: _CreateTicketModalPartial -->
        </div>
    </div>
</div>

<!-- Ticket Edit Modal -->
<div class="modal fade" id="editTicketModal" tabindex="-1" aria-labelledby="editTicketModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" id="editModalContent">
            <!-- Partial View: _EditTicketModalPartial -->
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // --- 1. LOAD AND SHOW CREATE MODAL ---
        function openCreateModal() {
            $.get('@Url.Action("CreatePartial", "Ticket")', function (data) {
                $('#createModalContent').html(data);
                $('#createTicketModal').modal('show');
                
                // Re-bind ASP.NET client-side validation for the injected form
                $.validator.unobtrusive.parse('#createModalContent form');
            });
        }

        // --- 2. LOAD AND SHOW EDIT MODAL ---
        function openEditModal(id) {
            $.get('@Url.Action("EditPartial", "Ticket")/' + id, function (data) {
                $('#editModalContent').html(data);
                $('#editTicketModal').modal('show');
                
                $.validator.unobtrusive.parse('#editModalContent form');
            });
        }

        // --- 3. HANDLE FORM SUBMISSIONS (CREATE & EDIT) ---
        // Event delegation because the forms are injected dynamically
        $(document).on('submit', '.ajax-modal-form', function (e) {
            e.preventDefault(); // Stop standard full-page submission
            
            var form = $(this);
            var modalContentId = form.closest('.modal-content').attr('id');

            $.ajax({
                url: form.attr('action'),
                type: form.attr('method'),
                data: form.serialize(),
                success: function (response) {
                    if (response.success) {
                        // Success: Close modal and refresh the page to show new data
                        // (This keeps your current URL filters intact!)
                        location.reload();
                    } else {
                        // Validation Failed: The controller returned the Partial View HTML with error messages.
                        // We replace the modal content with this new HTML.
                        $('#' + modalContentId).html(response);
                        $.validator.unobtrusive.parse('#' + modalContentId + ' form');
                    }
                },
                error: function () {
                    alert("An error occurred while saving. Please try again.");
                }
            });
        });
    </script>
}