@using TicketSystem.Web.Models.Project.Proposta
@model IEnumerable<ProjectListViewModel>

    <h2>Projects</h2>
    <div class="d-flex justify-content-end align-items-center my-2">
        <a asp-action="Create" class="btn btn-success">New Project</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    <hr class="my-4" />
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model)
        {
            int progress = item.TotalTickets > 0
                ? ((item.TotalTickets - item.OpenTickets) * 100) / item.TotalTickets
                : 0;

            <div class="col">
                <div class="card h-100 shadow-sm bg-light-subtle">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="badge bg-secondary">@item.WorkflowName</span>
                            @if (item.EndDate.HasValue)
                            {
                                <span class="badge bg-success">Concluído</span>
                            }
                        </div>
                        <h5 class="card-title fw-bold">@item.Title</h5>
                        <p class="card-text text-muted small">@item.DescriptionSnippet</p>
                        
                        <div class="mt-3">
                            <div class="d-flex justify-content-between small mb-1">
                                <span>Progresso</span>
                                <span>@progress%</span>
                            </div>
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar" role="progressbar" style="width: @progress%" aria-valuenow="@progress" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between align-items-center">
                        <small class="text-muted">Início: @item.StartDate.ToShortDateString()</small>
    
                        <div class="d-flex gap-2">
                            @if (User.IsInRole("Admin") && item.EndDate.HasValue)
                            {
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                      onsubmit="return confirm('Tem a certeza que deseja apagar este projeto? Esta ação removerá o projeto da lista.');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Apagar Projeto">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Details</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
