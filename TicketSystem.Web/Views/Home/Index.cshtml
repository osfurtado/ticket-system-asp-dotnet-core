@using TicketSystem.Web.Models.Home
@model LandingPageViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome - TicketSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { 
            background-color: #f8f9fa; 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding-top: 76px; /* Space for the fixed navbar */
        }
        .hero-section {
            background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
            color: white;
            padding: 80px 0;
            text-align: center;
        }
        .stat-card {
            border: none;
            border-radius: 10px;
            transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
        }
        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
        }
        .icon-box {
            width: 60px;
            height: 60px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-size: 1.8rem;
            margin-bottom: 15px;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm fixed-top">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary" href="#">
                <i class="bi bi-kanban"></i> Ticket System
            </a>
            <div class="d-flex gap-2">
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary px-4">Login</a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-primary px-4">Register</a>
            </div>
        </div>
    </nav>

    <section class="hero-section shadow-sm">
        <div class="container">
            <h1 class="display-4 fw-bold mb-3">Empower Your Team's Productivity</h1>
            <p class="lead mb-4 text-white-50">Streamline tasks, manage projects efficiently, and keep track of every issue in one unified platform.</p>
        </div>
    </section>

    <section class="container py-5">
        <div class="row g-4 text-center">
            
            <div class="col-md-4">
                <div class="card stat-card shadow-sm h-100 p-4 bg-white">
                    <div class="icon-box bg-primary text-white mx-auto">
                        <i class="bi bi-ticket-detailed"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Tickets</h4>
                    <h2 class="display-6 fw-bold text-primary mb-3">@Model.TotalTickets</h2>
                    <div class="d-flex justify-content-around text-muted small mt-auto border-top pt-3">
                        <div>
                            <span class="d-block fw-bold text-success"><i class="bi bi-door-open"></i> @Model.OpenTickets</span>
                            <span>Open</span>
                        </div>
                        <div>
                            <span class="d-block fw-bold text-secondary"><i class="bi bi-door-closed"></i> @Model.ClosedTickets</span>
                            <span>Closed</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card stat-card shadow-sm h-100 p-4 bg-white">
                    <div class="icon-box bg-success text-white mx-auto">
                        <i class="bi bi-briefcase"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Projects</h4>
                    <h2 class="display-6 fw-bold text-success mb-3">@Model.TotalProjects</h2>
                    <div class="d-flex justify-content-around text-muted small mt-auto border-top pt-3">
                        <div>
                            <span class="d-block fw-bold text-success"><i class="bi bi-activity"></i> @Model.ActiveProjects</span>
                            <span>Active</span>
                        </div>
                        <div>
                            <span class="d-block fw-bold text-secondary"><i class="bi bi-archive"></i> @Model.ClosedProjects</span>
                            <span>Finished</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card stat-card shadow-sm h-100 p-4 bg-white">
                    <div class="icon-box bg-warning text-white mx-auto">
                        <i class="bi bi-people"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Users</h4>
                    <h2 class="display-6 fw-bold text-warning mb-3">@Model.TotalUsers</h2>
                    <div class="d-flex justify-content-around text-muted small mt-auto border-top pt-3">
                        @foreach (var role in Model.UsersByRole)
                        {
                            <div>
                                <span class="d-block fw-bold text-dark">@role.UserCount</span>
                                <span>@role.RoleName</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>
    </section>

    <footer class="text-center py-4 text-muted small">
        <div class="container">
           &copy; @DateTime.Now.Year - Ticket System. All rights reserved.
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>