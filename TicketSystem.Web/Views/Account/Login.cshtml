@using TicketSystem.Web.Models.Account
@model LoginModel

@{
    Layout = null;
}


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - TicketSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { background-color: #f8f9fa; display: flex; align-items: center; justify-content: center; height: 100vh; margin: 0; }
        .login-card { background: white; padding: 40px; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); width: 100%; max-width: 400px; text-align: center; }
    </style> 
</head>
<body>
    <div class="login-card">
        <i class="bi bi-kanban text-primary" style="font-size: 4rem;"></i>
        <h3 class="mb-4 mt-2">Ticket System</h3>

        <form asp-controller="Account" asp-action="Login" method="post" class="text-start">
            <input type="hidden" asp-for="ReturnUrl" />
            <div class="mb-3">
                <label asp-for="Username" class="form-label text-muted"></label>
                <input asp-for="Username" class="form-control form-control-sm" placeholder="Enter username" />
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Password" class="form-label text-muted"></label>
                <input type="password" asp-for="Password" class="form-control form-control-sm" placeholder="Enter password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="text-danger mb-3" asp-validation-summary="ModelOnly"></div>
            <button type="submit" class="btn btn-primary btn-sm w-100">Login</button>
            <div class="d-flex justify-content-between flex-sm-wrap">
                <a asp-action="Register" class="btn btn-link mt-2">I do not have an account</a>
                <a asp-controller="Home" asp-action="Index" class="btn btn-link mt-2">Back</a>
            </div>
        </form>
    </div>
</body>
</html>
